# Supabase — values with NEXT_PUBLIC_* are exposed to the browser. Use only the publishable key there.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Server-only: service role (bypasses RLS). Never prefix with NEXT_PUBLIC or import in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only: used by /api/macro-targets to call Claude.
ANTHROPIC_API_KEY=
