// ─── TRACKING ───
function getTodayKey() { return new Date().toISOString().split('T')[0]; }

function renderTracking() {
  const today = getTodayKey();
  const log = foodLog[today] || [];
  const totals = log.reduce((acc, f) => ({ cal: acc.cal + (+f.cal||0), pro: acc.pro + (+f.pro||0), fat: acc.fat + (+f.fat||0), carbs: acc.carbs + (+f.carbs||0) }), { cal:0, pro:0, fat:0, carbs:0 });

  const dateEl = document.getElementById('trackingDate');
  const dayLabel = document.getElementById('trackingDayLabel');
  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  dateEl.textContent = new Date().toLocaleDateString('en-US', { month:'long', day:'numeric', year:'numeric' });
  dayLabel.textContent = days[new Date().getDay()];

  const bars = document.getElementById('macroBars');
  const macros = [
    { label: 'Calories', val: totals.cal, target: TARGETS.cal, color: '#e8c870', unit: '' },
    { label: 'Protein', val: totals.pro, target: TARGETS.pro, color: '#7ab3d4', unit: 'g' },
    { label: 'Fat', val: totals.fat, target: TARGETS.fat, color: '#d4a57a', unit: 'g' },
    { label: 'Carbs', val: totals.carbs, target: TARGETS.carbs, color: '#a07ad4', unit: 'g' },
  ];
  bars.innerHTML = macros.map(m => {
    const pct = Math.min((m.val / m.target) * 100, 100);
    const over = m.val > m.target * 1.15;
    const close = m.val > m.target * 0.85 && m.val <= m.target * 1.15;
    const good = m.val >= m.target * 0.85 && m.val <= m.target * 1.05;
    const barColor = m.label === 'Calories' && m.val > TARGETS.cal ? 'var(--red)' : good ? 'var(--green)' : close ? 'var(--yellow)' : m.val > m.target ? 'var(--red)' : m.color;
    const arrow = m.label === 'Protein' && m.val < m.target ? ' ⬆️' : '';
    return `<div class="macro-bar-row">
      <div class="macro-bar-label">${m.label}</div>
      <div class="macro-bar-track"><div class="macro-bar-fill" style="width:${pct}%;background:${barColor}"></div></div>
      <div class="macro-bar-val" style="color:${barColor}">${m.val}${m.unit}${arrow}</div>
    </div>`;
  }).join('');

  const status = document.getElementById('macroStatus');
  const calOver = totals.cal > TARGETS.cal;
  const proShort = totals.pro < TARGETS.pro * 0.85;
  const fatOver = totals.fat > TARGETS.fat;
  if (calOver) {
    status.innerHTML = `<div class="macro-status" style="background:#ef444422;color:#ef4444">🔴 Calories over ceiling — ${totals.cal} / ${TARGETS.cal}</div>`;
  } else if (fatOver) {
    status.innerHTML = `<div class="macro-status" style="background:#ef444422;color:#ef4444">🔴 Fat over limit — ${totals.fat}g / ${TARGETS.fat}g</div>`;
  } else if (proShort) {
    status.innerHTML = `<div class="macro-status" style="background:#f59e0b22;color:#f59e0b">🟡 Protein short — ${totals.pro}g / ${TARGETS.pro}g ⬆️ Eat more protein</div>`;
  } else if (totals.cal > 0) {
    status.innerHTML = `<div class="macro-status" style="background:#10b98122;color:#10b981">🟢 On track — great job today!</div>`;
  } else {
    status.innerHTML = `<div class="macro-status" style="background:var(--surface2);color:var(--text2)">Log your first meal to see status</div>`;
  }

  const logList = document.getElementById('foodLogList');
  logList.innerHTML = '';
  if (log.length === 0) {
    logList.innerHTML = '<div style="text-align:center;color:var(--text3);font-size:13px;padding:20px;">No food logged today yet</div>';
  } else {
    log.forEach((item, i) => {
      const el = document.createElement('div');
      el.className = 'food-log-item';
      el.innerHTML = `<div><div class="food-log-name">${item.name}</div><div class="food-log-macros">${item.cal} cal · ${item.pro}g protein · ${item.fat}g fat · ${item.carbs}g carbs</div></div>
        <button class="food-log-del" onclick="deleteFoodEntry(${i})">×</button>`;
      logList.appendChild(el);
    });
  }
}

