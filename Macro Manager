function drawWeightChart(entries) {
  const canvas = document.getElementById('weightChart');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  canvas.width = canvas.offsetWidth * 2;
  canvas.height = 320;
  ctx.scale(2, 2);
  const w = canvas.offsetWidth / 2;
  const h = 160;
  const pad = { t: 20, r: 20, b: 30, l: 40 };
  const weights = entries.map(e => e.weight);
  const minW = Math.min(...weights) - 2;
  const maxW = Math.max(...weights) + 2;
  ctx.clearRect(0, 0, w, h);
  ctx.strokeStyle = '#1e2d42';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = pad.t + ((h - pad.t - pad.b) / 4) * i;
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(w - pad.r, y); ctx.stroke();
    const val = maxW - ((maxW - minW) / 4) * i;
    ctx.fillStyle = '#475569'; ctx.font = '10px DM Sans'; ctx.textAlign = 'right';
    ctx.fillText(val.toFixed(0), pad.l - 4, y + 4);
  }
  const xStep = (w - pad.l - pad.r) / Math.max(entries.length - 1, 1);
  const yScale = (h - pad.t - pad.b) / (maxW - minW);
  ctx.beginPath();
  entries.forEach((e, i) => {
    const x = pad.l + i * xStep;
    const y = pad.t + (maxW - e.weight) * yScale;
    i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
  });
  ctx.strokeStyle = '#3b82f6'; ctx.lineWidth = 2; ctx.stroke();
  entries.forEach((e, i) => {
    const x = pad.l + i * xStep;
    const y = pad.t + (maxW - e.weight) * yScale;
    ctx.beginPath(); ctx.arc(x, y, 4, 0, Math.PI * 2);
    ctx.fillStyle = '#3b82f6'; ctx.fill();
    ctx.fillStyle = '#e2e8f0'; ctx.font = 'bold 10px DM Sans'; ctx.textAlign = 'center';
    ctx.fillText(e.weight, x, y - 8);
    ctx.fillStyle = '#475569'; ctx.font = '9px DM Sans';
    ctx.fillText(e.date, x, h - pad.b + 14);
  });
}

